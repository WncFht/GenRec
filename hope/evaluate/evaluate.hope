[base]
type = ml-easy-job

[resource]
usergroup = hadoop-hmart-poistar
queue = root.zw05_training_cluster.hadoop-poistar.job_80g

[roles]
workers = 1
worker.memory = 65536
worker.vcore = 32
worker.gcores80g = 4
worker.script = bash /mnt/dolphinfs/hdd_pool/docker/user/hadoop-hmart-poistar/fanghaotian/GenRec/hope/evaluate/evaluate.sh

[user_args]

[am]
afo.app.am.resource.mb = 4096

[tensorboard]
with.tensor.board = false

[docker]
afo.docker.image.name = registry-offlinebiz.sankuai.com/custom_prod/com.sankuai.data.hadoop.gpu/intelligence-studio/training_codelab_pytorch2.4.1_cuda12.4_python310_quanta_vllm_v1_c7f4e3d4:v1.0.0

[data]
afo.data.prefetch = false

[failover]
afo.app.support.engine.failover = true

[conda]

[config]

[others]
afo.app.env.YARN_CONTAINER_RUNTIME_DOCKER_SHM_SIZE_BYTES = 137438953472
afo.role.worker.env.YARN_CONTAINER_RUNTIME_DOCKER_SHM_SIZE_BYTES = 137438953472
afo.xm.notice.receivers.account = fanghaotian@meituan.com
with_requirements = false
afo.dolphinfs.otherusers = hadoop-hmart-poistar:false

